# ══════════════════════════════════════════════════════════════════════════════
# liblingua — Environment variables template
# Copy this file to .env at the PROJECT ROOT and fill in your values.
# This is the ONLY .env file you need. Docker Compose passes everything
# to every container automatically. Do NOT create backend/.env.
# ══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL (Docker internal container) ────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me                  # openssl rand -hex 32
POSTGRES_DB=liblingua_db

# ── External database override (optional) ─────────────────────────────────────
# Set this to use an external DB (Neon, Supabase, etc.) instead of Docker postgres.
# Leave blank to use the Docker postgres container above.
DATABASE_URL=

# ── JWT / Session ─────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-64-char-random-string   # openssl rand -hex 64
JWT_EXPIRES_IN=7d

# ── Node environment (production | development) ───────────────────────────────
NODE_ENV=production

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com
OAUTH_CALLBACK_BASE=https://yourdomain.com

# ── Admin seed account (created on first run) ─────────────────────────────────
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=change-me

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Leave blank to disable email verification (dev mode — links print to logs).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@liblingua.org

# ── Google OAuth ──────────────────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── AWS S3 (optional — leave blank to store audio on disk) ───────────────────
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ── Stripe (card payments) ────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── MTN Mobile Money ──────────────────────────────────────────────────────────
# https://momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com

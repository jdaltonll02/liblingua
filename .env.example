# ── Copy this to .env and fill in your values ────────────────────────────────
# Used by docker-compose.yml and docker-compose.dev.yml

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lmd_db

# JWT — CHANGE THIS before deploying
JWT_SECRET=change-me-to-a-long-random-string

# Node environment  (production | development)
NODE_ENV=production

# Seed admin credentials (used by scripts/seed.js on first run)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123

# Email / SMTP — leave blank to disable verification emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@liblingua.org

# AWS S3 — leave blank to store audio files on disk
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ── Stripe (card payments) ───────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
# Use sk_test_xxx / pk_test_xxx for testing, sk_live_xxx / pk_live_xxx for production
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ── MTN Mobile Money ─────────────────────────────────────────────────────────
# Register at https://momodeveloper.mtn.com and create a Collection app
# Sandbox: MTN_MOMO_ENVIRONMENT=sandbox  |  Production: MTN_MOMO_ENVIRONMENT=mtncongo / mtngh / etc.
MTN_MOMO_SUBSCRIPTION_KEY=your_subscription_key_here
MTN_MOMO_API_USER=your_api_user_uuid_here
MTN_MOMO_API_KEY=your_api_key_here
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com

# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment — never commit secrets
.env
backend/.env
frontend/.env

# Build output
frontend/dist/
frontend/.vite/

# Prisma generated client (regenerated by prisma generate)
backend/node_modules/.prisma/

# Uploaded audio files (large binaries — store in S3/object storage for production)
uploads/audio/*/*/

# Log files (written by Winston — never commit)
logs/
*.log
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
